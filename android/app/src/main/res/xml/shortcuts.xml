<?xml version="1.0" encoding="utf-8"?>
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">
    <shortcut
        android:shortcutId="quick_camera"
        android:enabled="true"
        android:icon="@mipmap/ic_launcher"
        android:shortcutShortLabel="@string/shortcut_camera"
        android:shortcutLongLabel="@string/shortcut_camera_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.exacta.app"
            android:targetClass="com.exacta.app.MainActivity"
            android:data="exacta://camera" />
    </shortcut>
    <shortcut
        android:shortcutId="quick_gallery"
        android:enabled="true"
        android:icon="@mipmap/ic_launcher"
        android:shortcutShortLabel="@string/shortcut_gallery"
        android:shortcutLongLabel="@string/shortcut_gallery_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.exacta.app"
            android:targetClass="com.exacta.app.MainActivity"
            android:data="exacta://gallery" />
    </shortcut>
</shortcuts>
