/* Exacta — iOS 권한 사유 문구 (한국어) */

"CFBundleDisplayName" = "Exacta";

"NSCameraUsageDescription" = "Exacta는 타임스탬프·GPS·위변조 방지 메타데이터가 픽셀에 합성된 사진과 영상을 촬영하기 위해 카메라를 사용합니다.";

"NSMicrophoneUsageDescription" = "Exacta는 현장 영상 촬영 시 음성 녹음을 위해 마이크를 사용합니다.";

"NSLocationWhenInUseUsageDescription" = "Exacta는 촬영 시각과 장소에 대한 위변조 불가 증거를 남기기 위해 GPS 좌표와 주소를 사진 스탬프에 기록합니다. 보안 촬영 모드에서는 위치 정보를 절대 사용하지 않습니다.";

"NSPhotoLibraryUsageDescription" = "Exacta는 스탬프용 로고 이미지를 선택하고 내보낸 사진을 공유하기 위해 사진 라이브러리에 접근합니다.";

"NSPhotoLibraryAddUsageDescription" = "Exacta는 촬영한 사진을 시스템 사진 보관함에 저장하여 다른 사진과 함께 확인할 수 있도록 합니다.";
